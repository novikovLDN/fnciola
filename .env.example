# Holdy — пример переменных окружения (Аддендум №1, §3).
# В репозиторий попадает только этот файл БЕЗ реальных значений.
# Все секреты/адреса задаются в Railway Variables. Хардкод недопустим.

# --- App ---
NODE_ENV=development
# PORT инжектится Railway автоматически; приложение слушает 0.0.0.0:$PORT
PORT=3000
APP_URL=http://localhost:3000

# --- Управляются Railway ссылками (§3.1) ---
# DATABASE_URL=${{Postgres.DATABASE_URL}}   # приватная сеть *.railway.internal
# REDIS_URL=${{Redis.REDIS_URL}}
DATABASE_URL=postgres://holdy:holdy@localhost:5432/holdy
REDIS_URL=redis://localhost:6379
DB_POOL_MAX=10

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET=change-me-long-random-secret
BETTER_AUTH_URL=http://localhost:3000
# Шифрование чувствительных полей на уровне приложения (32 байта, base64)
APP_ENCRYPTION_KEY=

# --- Web Push (VAPID, §13) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@holdy.app

# --- Email через Resend (OTP-коды регистрации/входа/восстановления) ---
# Получить ключ: https://resend.com/api-keys. Без ключа в dev код печатается в лог.
RESEND_API_KEY=
EMAIL_FROM="Holdy <onboarding@resend.dev>"

# --- (Опционально) SMTP, если не Resend ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- S3-совместимое хранилище выписок (§7, вариант А: R2/Backblaze) ---
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# --- Курсы валют (§8) ---
FX_PROVIDER=cbr
FX_API_BASE_URL=
FX_API_KEY=

# --- Платежи (Platecha, §12) ---
PLATECHA_API_URL=
PLATECHA_API_KEY=
PLATECHA_SECRET=
PLATECHA_WEBHOOK_SECRET=
